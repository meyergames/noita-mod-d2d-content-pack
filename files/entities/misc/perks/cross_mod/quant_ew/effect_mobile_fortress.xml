<Entity tags="perk_entity,d2d_perk_mobile_fortress" >

    <InheritTransformComponent />
  
    <GameEffectComponent 
        effect="CUSTOM"
        custom_effect_id="D2D_GAME_EFFECT_MOBILE_FORTRESS"
    ></GameEffectComponent >

    <LuaComponent
      _enabled="1" 
      script_source_file="mods/D2DContentPack/files/scripts/perks/cross_mod/quant_ew/effect_mobile_fortress_update.lua"
      execute_every_n_frame="1"
    ></LuaComponent>

    <!-- 3 shields as children -->
    <Entity>
        <Base file="mods/D2DContentPack/files/entities/misc/perks/cross_mod/quant_ew/mobile_fortress_shield.xml" />

        <!-- only the first one has inner particles -->
        <ParticleEmitterComponent 
            emitted_material_name="magic_liquid_mana_regeneration"
            gravity.y="0.0"
            lifetime_min="1.2"
            lifetime_max="1.9"
            count_min="2"
            count_max="3"
            render_on_grid="1"
            fade_based_on_lifetime="1"
            area_circle_radius.max="48"
            cosmetic_force_create="0"
            airflow_force="0.2"
            airflow_time="0.9"
            airflow_scale="0.15"
            emission_interval_min_frames="1"
            emission_interval_max_frames="2"
            emit_cosmetic_particles="1"
            x_vel_min="-10"
            x_vel_max="10"
            y_vel_min="-10"
            y_vel_max="10"
            is_emitting="1" >
        </ParticleEmitterComponent>
    </Entity>

    <Entity>
        <Base file="mods/D2DContentPack/files/entities/misc/perks/cross_mod/quant_ew/mobile_fortress_shield.xml" >
            <EnergyShieldComponent
                radius="52.0"
            ></EnergyShieldComponent>
            <ParticleEmitterComponent
                area_circle_radius.min="52"
                area_circle_radius.max="52"
            ></ParticleEmitterComponent>
            <ParticleEmitterComponent
                area_circle_radius.min="52"
                area_circle_radius.max="52"
            ></ParticleEmitterComponent>
        </Base>
    </Entity>

    <Entity>
        <Base file="mods/D2DContentPack/files/entities/misc/perks/cross_mod/quant_ew/mobile_fortress_shield.xml" >
            <EnergyShieldComponent
                radius="56.0"
            ></EnergyShieldComponent>
            <ParticleEmitterComponent
                area_circle_radius.min="56"
                area_circle_radius.max="56"
            ></ParticleEmitterComponent>
            <ParticleEmitterComponent
                area_circle_radius.min="56"
                area_circle_radius.max="56"
            ></ParticleEmitterComponent>
        </Base>
    </Entity>

</Entity>
