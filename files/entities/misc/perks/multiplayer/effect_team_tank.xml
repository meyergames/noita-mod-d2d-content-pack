<Entity tags="perk_entity,d2d_perk_team_tank" >

    <InheritTransformComponent />
  
    <GameEffectComponent 
        effect="CUSTOM"
        custom_effect_id="D2D_GAME_EFFECT_TEAM_TANK"
    ></GameEffectComponent >

    <LuaComponent
      _enabled="1"
      script_source_file="mods/D2DContentPack/files/scripts/perks/multiplayer/effect_team_tank_scan.lua"
      execute_every_n_frame="300"
    ></LuaComponent>

    <ParticleEmitterComponent
        _tags="character,enabled_in_hand,item_identified__LEGACY,shield_ring"
        emitted_material_name="spark_yellow"
        gravity.y="0.0"
        lifetime_min="0.1"
        lifetime_max="0.25"
        count_min="20"
        count_max="30"
        render_on_grid="1"
        fade_based_on_lifetime="1"
        area_circle_radius.min="80"
        area_circle_radius.max="80"
        cosmetic_force_create="0"
        airflow_force="0.3"
        airflow_time="0.01"
        airflow_scale="0.05"
        emission_interval_min_frames="0"
        emission_interval_max_frames="0"
        emit_cosmetic_particles="1"
        is_emitting="1" >
    </ParticleEmitterComponent>

    <!-- outer edge -->
    <ParticleEmitterComponent 
        emitted_material_name="spark_yellow"
        gravity.y="0.0"
        lifetime_min="0.4"
        lifetime_max="1.4"
        count_min="1"
        count_max="2"
        render_on_grid="1"
        fade_based_on_lifetime="1"
        area_circle_radius.min="72"
        area_circle_radius.max="80"
        cosmetic_force_create="0"
        airflow_force="0.2"
        airflow_time="0.3"
        airflow_scale="0.05"
        emission_interval_min_frames="1"
        emission_interval_max_frames="1"
        emit_cosmetic_particles="1"
        draw_as_long="1"
        x_vel_min="-1"
        x_vel_max="1"
        y_vel_min="-1"
        y_vel_max="1"
        is_emitting="1" 
        velocity_always_away_from_center="-25"
    ></ParticleEmitterComponent>

</Entity>
